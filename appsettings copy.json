{
  "Backup": {
    "IntervalSeconds": 3600,
    "Host": "localhost",
    "User": "postgres",
    "PasswordParameterName": "/redwoodiloilo/backup-agent/postgres-password",
    "Database": "postgres",
    "BackupDirectory": "./backups",
    "PgDumpPath": "tools\\pg_dump.bat",
    "PgRestorePath": "tools\\pg_restore.bat",
    "CompressionLevel": 9,
    "RetentionDays": 7
  }
}
